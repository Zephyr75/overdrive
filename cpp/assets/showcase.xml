<?xml version="1.0" ?>
<!-- Overdrive feature showcase. Geometry is baked into the Demo*.obj vertices
     (engine renders with an identity model matrix), so <position> is unused for
     static meshes. Up to 8 lights are supported in any order; the first
     directional and first point light cast shadows. -->
<scene>
	<camera name="Camera">
		<type>persp</type>
		<position>0.0,-9.5,3.5</position>
		<yaw>0.0</yaw>
		<pitch>14.0</pitch>
		<fov>45.0</fov>
	</camera>

	<!-- Paving-stone ground: normal-mapped flat surface, catches both shadows -->
	<mesh name="Ground">
		<position>0.0,0.0,0.0</position>
		<obj>DemoGround.obj</obj>
	</mesh>

	<!-- Hero: metal Suzanne, normal-mapped, high specular -->
	<mesh name="Suzanne">
		<position>0.0,0.0,0.0</position>
		<obj>DemoSuzanne.obj</obj>
	</mesh>

	<!-- Polished chrome sphere: low Kd → skybox reflection dominates -->
	<mesh name="SphereChrome">
		<position>0.0,0.0,0.0</position>
		<obj>DemoSphereChrome.obj</obj>
	</mesh>

	<!-- Brick sphere: normal mapping on a curved surface -->
	<mesh name="SphereBrick">
		<position>0.0,0.0,0.0</position>
		<obj>DemoSphereBrick.obj</obj>
	</mesh>

	<!-- Wood cube: normal mapping on flat faces -->
	<mesh name="Cube">
		<position>0.0,0.0,0.0</position>
		<obj>DemoCube.obj</obj>
	</mesh>

	<!-- Five lights, placed so each is easy to tell apart:
	     - warm point above centre  -> casts the cube shadow (first point)
	     - red point on the left, green on the right, blue in front -> distinct
	       coloured pools on the ground and props
	     - white sun overhead       -> casts the 2D shadow (first directional)
	     XML position is (GLx, -GLz, GLy) because of the Blender->GL axis swap. -->

	<!-- warm point, GL (1.0, 4.0, 1.5), above the scene -> cube shadow caster -->
	<light name="PointWarm">
		<type>point</type>
		<position>1.0,-1.5,4.0</position>
		<direction>0.0,0.0,-1.0</direction>
		<color>1.0,0.85,0.6</color>
		<diffuse>1.0</diffuse>
		<specular>1.0</specular>
		<intensity>9000.0</intensity>
	</light>

	<!-- red point, GL (-4.5, 1.0, 1.8), low by the chrome sphere -->
	<light name="PointRed">
		<type>point</type>
		<position>-4.5,-1.8,1.0</position>
		<direction>0.0,0.0,-1.0</direction>
		<color>1.0,0.1,0.1</color>
		<diffuse>1.0</diffuse>
		<specular>1.0</specular>
		<intensity>8000.0</intensity>
	</light>

	<!-- green point, GL (4.5, 1.0, 1.8), low by the brick sphere -->
	<light name="PointGreen">
		<type>point</type>
		<position>4.5,-1.8,1.0</position>
		<direction>0.0,0.0,-1.0</direction>
		<color>0.1,1.0,0.1</color>
		<diffuse>1.0</diffuse>
		<specular>1.0</specular>
		<intensity>8000.0</intensity>
	</light>

	<!-- blue point, GL (0.0, 0.9, 3.8), low and in front of Suzanne -->
	<light name="PointBlue">
		<type>point</type>
		<position>0.0,-3.8,0.9</position>
		<direction>0.0,0.0,-1.0</direction>
		<color>0.2,0.3,1.0</color>
		<diffuse>1.0</diffuse>
		<specular>1.0</specular>
		<intensity>7000.0</intensity>
	</light>

	<!-- sun -> directional 2D shadow map (first directional = caster). direction
	     points toward the light (up); the shadow camera looks along pos - direction.
	     Kept dim so the coloured point lights stay visible. -->
	<light name="Sun">
		<type>sun</type>
		<position>6.0,-5.0,12.0</position>
		<direction>-0.35,0.45,-1.0</direction>
		<color>1.0,0.98,0.92</color>
		<diffuse>1.0</diffuse>
		<specular>1.0</specular>
		<intensity>2.0</intensity>
	</light>
</scene>
